# Clés accès bucket supabase
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=dossiers
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=