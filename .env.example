# Generer une cle: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Vide = SQLite en local. En prod: URL du Session pooler Supabase
